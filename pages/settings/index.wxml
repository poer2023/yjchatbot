<view class="settings-page theme-shell {{themeClass}}">
  <view class="page-glow glow-a"></view>
  <view class="page-glow glow-b"></view>

  <view class="settings-shell">
    <view class="settings-header">
      <view class="header-safe" style="height: {{statusBarHeight}}px;"></view>
      <view class="settings-top">
        <view class="back-button" bindtap="handleBack">
          <text>Back</text>
        </view>
        <view class="settings-heading">
          <text class="settings-title">Demo Settings</text>
          <text class="settings-subtitle">控制默认模型、主题、流式速度和本地缓存。</text>
        </view>
      </view>
    </view>

    <scroll-view class="settings-scroll" scroll-y="{{true}}" show-scrollbar="{{false}}">
      <view class="settings-stack">
        <view class="settings-card shell-panel">
          <text class="card-eyebrow">DEFAULT MODEL</text>
          <text class="card-title">新会话默认模型</text>
          <text class="card-copy">当前设置只影响后续新建会话，不会强制改写已有会话。</text>
          <view class="option-list">
            <block wx:for="{{models}}" wx:key="id">
              <view
                class="option-card {{settings.defaultModelId === item.id ? 'option-card-active' : ''}}"
                data-id="{{item.id}}"
                bindtap="handleModelPick"
              >
                <view class="option-leading">
                  <view class="option-accent" style="background: {{item.accent}};"></view>
                  <text class="option-title">{{item.name}}</text>
                </view>
                <text class="option-description">{{item.description}}</text>
              </view>
            </block>
          </view>
        </view>

        <view class="settings-card shell-panel">
          <text class="card-eyebrow">LOOK & FEEL</text>
          <text class="card-title">界面主题</text>
          <text class="card-copy">当前主题：{{themeLabel}}</text>
          <view class="option-list">
            <block wx:for="{{themeOptions}}" wx:key="id">
              <view
                class="option-card {{settings.theme === item.id ? 'option-card-active' : ''}}"
                data-id="{{item.id}}"
                bindtap="handleThemePick"
              >
                <view class="option-leading">
                  <text class="option-title">{{item.title}}</text>
                </view>
                <text class="option-description">{{item.description}}</text>
              </view>
            </block>
          </view>
        </view>

        <view class="settings-card shell-panel">
          <text class="card-eyebrow">PLAYBACK</text>
          <text class="card-title">流式回复速度</text>
          <text class="card-copy">当前节奏：{{typingSpeedLabel}} · {{settings.typingSpeed}} ms / step</text>
          <slider
            activeColor="#1f8d72"
            backgroundColor="rgba(120, 120, 120, 0.16)"
            block-color="#ffffff"
            block-size="24"
            max="54"
            min="18"
            show-value="{{false}}"
            step="2"
            value="{{settings.typingSpeed}}"
            bindchange="handleTypingSpeedChange"
          />
        </view>

        <view class="settings-card shell-panel">
          <text class="card-eyebrow">BEHAVIOR</text>
          <text class="card-title">演示行为</text>
          <view class="switch-row">
            <view>
              <text class="switch-title">显示欢迎态</text>
              <text class="switch-copy">空白会话时展示起手提示和推荐问题。</text>
            </view>
            <switch
              checked="{{settings.showWelcome}}"
              color="#1f8d72"
              bindchange="handleWelcomeChange"
            />
          </view>
          <view class="switch-row">
            <view>
              <text class="switch-title">本地持久化</text>
              <text class="switch-copy">关闭后仅保留设置，不保存会话历史。</text>
            </view>
            <switch
              checked="{{settings.persistHistory}}"
              color="#1f8d72"
              bindchange="handlePersistChange"
            />
          </view>
        </view>

        <view class="settings-card shell-panel danger-card">
          <text class="card-eyebrow">RESET</text>
          <text class="card-title">重置本地 Demo</text>
          <text class="card-copy">删除会话、消息、模型偏好和主题设置，恢复到初始演示状态。</text>
          <view class="danger-button" bindtap="handleClearAll">
            <text>Clear local data</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
