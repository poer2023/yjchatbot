.message-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.message-row + .message-row {
  margin-top: 18rpx;
}

.message-row-user {
  justify-content: flex-end;
}

.assistant-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 56rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  box-shadow: none;
  overflow: hidden;
}

.assistant-avatar-image {
  width: 100%;
  height: 100%;
}

.message-main {
  max-width: 84%;
}

.message-main-user {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.message-meta {
  margin-bottom: 8rpx;
  color: #b0b4bc;
  font-size: 21rpx;
  line-height: 1.4;
}

.message-bubble {
  overflow: hidden;
  border-radius: 30rpx;
  border: 1rpx solid #e8e8e8;
  box-shadow: none;
}

.message-bubble-assistant {
  padding: 24rpx 24rpx;
  background: #ffffff;
}

.message-bubble-user {
  padding: 20rpx 24rpx;
  border-color: transparent;
  background: #eff1ff;
  color: #35416a;
}

.message-bubble-typing {
  padding: 24rpx;
}

.message-text {
  color: inherit;
  font-size: 27rpx;
  line-height: 1.72;
  white-space: pre-wrap;
  word-break: break-word;
}

.message-bubble-assistant .message-text {
  color: #1c1c1c;
}

.typing-dots {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 84rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #bbbbbb;
  opacity: 0.55;
}
