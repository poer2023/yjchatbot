.chat-input {
  position: relative;
  z-index: 3;
  margin: 0;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: transparent;
}

.input-search-chips {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.search-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 52rpx;
  min-width: 0;
  padding: 0 10rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e4e8ef;
  color: #2f3640;
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1;
  white-space: nowrap;
  box-shadow: 0 2rpx 10rpx rgba(29, 34, 42, 0.06);
}

.search-chip:active {
  opacity: 0.88;
}

.search-chip-active {
  background: #f3f5ff;
  border-color: #cfd9ff;
  color: #5b67ff;
  box-shadow: none;
}

.search-chip-icon {
  width: 22rpx;
  height: 22rpx;
  flex-shrink: 0;
  filter: grayscale(1) brightness(0.45);
}

.search-chip text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
}

.search-chip-active .search-chip-icon {
  filter: none;
}

.input-main-capsule {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  gap: 10rpx;
  padding: 12rpx 14rpx 12rpx 16rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #e5e9f0;
  box-shadow: 0 4rpx 14rpx rgba(28, 34, 44, 0.05);
}

.input-mic-wrap {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 2rpx;
}

.input-mic-wrap:active {
  opacity: 0.65;
}

.input-mic-icon {
  width: 40rpx;
  height: 40rpx;
}

.chat-textarea-flex {
  flex: 1;
  min-width: 0;
  min-height: 48rpx;
  max-height: 200rpx;
  padding: 10rpx 8rpx 12rpx;
  font-size: 28rpx;
  line-height: 1.55;
  color: #1f1f1f;
}

.textarea-placeholder {
  color: #a6adb8;
}

.input-trailing-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
  margin-bottom: 2rpx;
}

.input-circle-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.input-circle-plus {
  border: 2rpx solid #e2e6ee;
  background: #ffffff;
}

.input-plus-glyph {
  font-size: 40rpx;
  line-height: 1;
  color: #5c6370;
  font-weight: 400;
  transform: translateY(-2rpx);
}

.input-circle-plus:active {
  background: #f6f7fb;
}

.input-circle-send {
  background: #eceff4;
}

.input-circle-send-active {
  background: #2f3640;
  box-shadow: 0 6rpx 16rpx rgba(47, 54, 64, 0.28);
}

.input-circle-send:active {
  opacity: 0.92;
}

.send-plane-icon {
  width: 34rpx;
  height: 34rpx;
}

.send-loading {
  font-size: 36rpx;
  line-height: 1;
  color: #9aa3b5;
  transform: translateY(-2rpx);
}

.input-disclaimer {
  display: block;
  margin-top: 6rpx;
  text-align: center;
  font-size: 22rpx;
  color: #b8bcc8;
  line-height: 1.3;
  transform: translateY(6rpx);
}

.voice-mode-shell {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.voice-record-panel {
  width: 100%;
  padding: 8rpx 0 2rpx;
}

.voice-record-panel-top {
  margin-bottom: 10rpx;
}

.voice-wave-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  width: 100%;
  gap: 0;
}

.voice-wave-bar {
  width: 7rpx;
  min-height: 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #2464e8 0%, #2fe1d9 100%);
  animation: voice-wave-pulse 0.9s ease-in-out infinite;
}

.voice-hold-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-height: 88rpx;
  padding: 12rpx 14rpx 12rpx 16rpx;
  border: 1rpx solid #e5e9f0;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 14rpx rgba(28, 34, 44, 0.05);
}

.voice-hold-btn-recording {
  background: #7f9de8;
  border-color: #7f9de8;
  box-shadow: none;
}

.voice-hold-btn-cancel {
  background: #e43831;
  border-color: #e43831;
  box-shadow: none;
}

.voice-hold-leading,
.voice-hold-trailing {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.voice-hold-leading {
  border: 1rpx solid #d8dee8;
  background: #ffffff;
}

.voice-hold-leading-icon {
  width: 42rpx;
  height: 42rpx;
}

.voice-hold-trailing {
  background: #eceff4;
}

.voice-hold-trailing-icon {
  width: 34rpx;
  height: 34rpx;
  opacity: 0.6;
}

.voice-hold-text {
  flex: 1;
  text-align: center;
  color: #1f242c;
  font-size: 30rpx;
  font-weight: 650;
  line-height: 1;
}

.voice-hold-btn-recording .voice-hold-leading,
.voice-hold-btn-recording .voice-hold-trailing,
.voice-hold-btn-cancel .voice-hold-leading,
.voice-hold-btn-cancel .voice-hold-trailing {
  opacity: 0;
}

.voice-hold-btn-recording .voice-hold-text {
  color: #5f7ec7;
}

.voice-hold-btn-cancel .voice-hold-text {
  color: #ffffff;
}

@keyframes voice-wave-pulse {
  0%,
  100% {
    transform: scaleY(0.62);
    opacity: 0.78;
  }
  50% {
    transform: scaleY(1);
    opacity: 1;
  }
}
