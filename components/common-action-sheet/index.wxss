.common-sheet-layer {
  position: fixed;
  inset: 0;
  z-index: 990;
  opacity: 0;
  pointer-events: none;
  transition: opacity 180ms ease;
}

.common-sheet-layer-visible {
  opacity: 1;
  pointer-events: auto;
}

.common-sheet-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.42);
}

.common-sheet-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  transform: translateY(108%);
  transition: transform 200ms ease;
}

.common-sheet-layer-visible .common-sheet-panel {
  transform: translateY(0);
}

.common-sheet-card {
  overflow: hidden;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 12rpx);
}

.common-sheet-option,
.common-sheet-cancel {
  width: 100%;
  min-height: 92rpx;
  border: none;
  background: #fff;
  color: #23262c;
  font-size: 32rpx;
  font-weight: 400;
  text-align: center;
  line-height: 1.2;
  padding: 0;
}

.common-sheet-option::after,
.common-sheet-cancel::after {
  border: none;
}

.common-sheet-option:active,
.common-sheet-cancel:active {
  background: #f6f7f9;
}

.common-sheet-separator {
  height: 1px;
  background: #ededf0;
}
