<view class="common-sheet-layer {{visible ? 'common-sheet-layer-visible' : ''}}">
  <view class="common-sheet-mask" bindtap="handleMaskTap" catchtouchmove="noop"></view>
  <view class="common-sheet-panel" catchtap="noop" catchtouchmove="noop">
    <view class="common-sheet-card">
      <block wx:for="{{options}}" wx:key="key">
        <button
          class="common-sheet-option"
          data-key="{{item.key}}"
          data-label="{{item.label}}"
          bindtap="handleOptionTap"
        >
          {{item.label}}
        </button>
        <view wx:if="{{index < options.length - 1}}" class="common-sheet-separator"></view>
      </block>
      <view class="common-sheet-separator"></view>
      <button class="common-sheet-cancel" bindtap="handleCancel">{{cancelText}}</button>
    </view>
  </view>
</view>
