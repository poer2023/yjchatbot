.drawer-shell {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  pointer-events: none;
}

.drawer-visible {
  pointer-events: auto;
}

.drawer-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(18, 16, 14, 0.26);
  opacity: 0;
  transition: opacity 220ms ease;
}

.drawer-visible .drawer-mask {
  opacity: 1;
}

.drawer-panel {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 560rpx;
  padding: 0 22rpx 20rpx;
  border-radius: 0;
  background: #ffffff;
  transform: translateX(-112%);
  transition: transform 240ms ease;
}

.drawer-visible .drawer-panel {
  transform: translateX(0);
}

.drawer-list {
  height: calc(100% - 120rpx);
}

.history-group + .history-group {
  margin-top: 14rpx;
}

.history-group-label {
  display: block;
  margin-bottom: 8rpx;
  color: #b7b7b7;
  font-size: 20rpx;
  line-height: 1.4;
}

.history-item {
  padding: 6rpx 4rpx;
  border-radius: 0;
}

.history-item + .history-item {
  margin-top: 6rpx;
}

.history-item-active {
  background: #f2f2f2;
}

.history-item-title {
  display: block;
  color: #191919;
  font-size: 29rpx;
  line-height: 1.42;
}

.drawer-footer {
  position: absolute;
  right: 22rpx;
  bottom: 16rpx;
  left: 22rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 70rpx;
}

.profile-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #d1d6df 0%, #7f8da3 100%);
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 700;
}

.profile-name {
  flex: 1;
  color: #1d1d1d;
  font-size: 26rpx;
}

.profile-more {
  color: #9f9f9f;
  font-size: 28rpx;
  letter-spacing: 0.08em;
}
