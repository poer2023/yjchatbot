<view class="drawer-shell {{visible ? 'drawer-visible' : ''}}">
  <view class="drawer-mask" bindtap="handleClose" catchtouchmove="noop"></view>
  <view class="drawer-panel" catchtap="noop" catchtouchmove="noop">
    <scroll-view scroll-y class="drawer-list" style="padding-top: {{topOffset}}px;">
      <block wx:for="{{groups}}" wx:key="label" wx:for-item="group">
        <view class="history-group">
          <text class="history-group-label">{{group.label}}</text>
          <block wx:for="{{group.items}}" wx:key="id" wx:for-item="session">
            <view
              class="history-item {{session.id === activeSessionId ? 'history-item-active' : ''}}"
              data-id="{{session.id}}"
              bindtap="handleSelect"
            >
              <text class="history-item-title">{{session.title}}</text>
            </view>
          </block>
        </view>
      </block>
    </scroll-view>

    <view class="drawer-footer" bindtap="handleSettings">
      <view class="profile-avatar">
        <text>{{profileInitial}}</text>
      </view>
      <text class="profile-name">{{profileName}}</text>
      <text class="profile-more">···</text>
    </view>
  </view>
</view>
