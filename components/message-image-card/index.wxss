.image-card {
  overflow: hidden;
  border-radius: 26rpx;
  border: 1rpx solid var(--border-soft);
  background: var(--surface-2);
}

.image-cover {
  position: relative;
  height: 220rpx;
  overflow: hidden;
  padding: 18rpx;
}

.cover-grid {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.18) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.18) 1rpx, transparent 1rpx);
  background-size: 36rpx 36rpx;
  opacity: 0.45;
}

.cover-pill,
.cover-caption {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  backdrop-filter: blur(12rpx);
  font-size: 22rpx;
  font-weight: 600;
}

.cover-caption {
  position: absolute;
  left: 18rpx;
  bottom: 18rpx;
}

.image-copy {
  padding: 22rpx;
}

.image-title {
  display: block;
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.image-description {
  display: block;
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.65;
}

.image-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.image-action {
  display: inline-flex;
  align-items: center;
  min-height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: var(--accent-soft);
  color: var(--accent-primary);
  font-size: 22rpx;
  font-weight: 600;
}

.image-metric {
  color: var(--text-tertiary);
  font-size: 22rpx;
}
