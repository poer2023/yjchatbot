<view class="image-card">
  <view
    class="image-cover"
    style="background: linear-gradient(135deg, {{card.accentStart || '#d8f0e7'}} 0%, {{card.accentEnd || '#245f8f'}} 100%);"
  >
    <view class="cover-grid"></view>
    <view class="cover-pill">
      <text>{{card.badge}}</text>
    </view>
    <view class="cover-caption">
      <text>{{card.eyebrow}}</text>
    </view>
  </view>
  <view class="image-copy">
    <text class="image-title">{{card.title}}</text>
    <text class="image-description">{{card.description}}</text>
    <view class="image-footer">
      <view class="image-action">
        <text>{{card.actionLabel}}</text>
      </view>
      <text class="image-metric">{{card.metric}}</text>
    </view>
  </view>
</view>
